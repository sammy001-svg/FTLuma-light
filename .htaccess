# FTLuma-Light — Routing, Performance & Security
RewriteEngine On

# ── Routing ───────────────────────────────────────────────────────────────────
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Force HTTPS (uncomment on live server if not handled by host)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Security ──────────────────────────────────────────────────────────────────
Options -Indexes

# Block direct access to sensitive PHP files
<FilesMatch "^(config|functions|db_test|debug_paths|check_admins|check_cats|create_comments_table|add_views_column|run_events_migration)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Custom error pages
ErrorDocument 404 /404.php

# ── PHP Limits ────────────────────────────────────────────────────────────────
php_value post_max_size 64M
php_value upload_max_filesize 16M
php_value max_execution_time 120
php_value memory_limit 256M

# ── Gzip Compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ── Browser Caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # Images — 1 year (fingerprinted by filename in practice)
    ExpiresByType image/jpeg  "access plus 1 year"
    ExpiresByType image/png   "access plus 1 year"
    ExpiresByType image/gif   "access plus 1 year"
    ExpiresByType image/webp  "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon  "access plus 1 year"

    # Fonts — 1 year
    ExpiresByType font/woff   "access plus 1 year"
    ExpiresByType font/woff2  "access plus 1 year"
    ExpiresByType application/font-woff  "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # CSS & JS — 1 week (short enough to pick up changes)
    ExpiresByType text/css        "access plus 1 week"
    ExpiresByType text/javascript "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"

    # HTML & XML — no cache (always fresh)
    ExpiresByType text/html       "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# Cache-Control headers as fallback
<IfModule mod_headers.c>
    <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    <FilesMatch "\.(woff|woff2)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=604800, public"
    </FilesMatch>
    # Remove ETags (Last-Modified is sufficient)
    Header unset ETag
</IfModule>
FileETag None

# ── Keep-Alive ────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>
